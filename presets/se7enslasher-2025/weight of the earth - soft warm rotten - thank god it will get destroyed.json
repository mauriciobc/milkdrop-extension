  "frame_eqs": "vol_att=bass_att+treb_Att+mid_att;\nbass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);\ntreb_thresh=above(treb_att,treb_thresh)*2+\n(1-above(treb_att,treb_thresh))*((treb_thresh-1.3)*0.96+1.3);\nmid_thresh=above(mid_att,mid_thresh)*2+\n(1-above(mid_mid_att,mid_thresh))*((mid_thresh-1.3)*0.96+1.3);\nvol_thresh=bass_thresh+treb_thresh+mid_thresh;\nreact=vol;\nnew_bass=if(above(react,bass_effect),bass-2&bass_att,bass_effect+bass_thresh);\nnew_treb=if(above(react,treb_effect),treb-2&treb_att,treb_Effect+treb_thresh);\nnew_mid=if(above(react,mid_effect),mid-2&mid_Att,mid_effect+mid_thresh);\nnew_vol=new_bass+new_treb+new_mid+.04;\nchange=bnot(1);\nq1=new_bass;\nq2=new_treb;\nq3=new_mid;\nq4=new_vol;\nq5=bass_thresh;\nq6=treb_thresh;\nq7=mid_thresh;\nq8=vol_thresh;\nwave_r=.3+.5*sin(q3-time);\nwave_g=.5-.2*sin(q2-time);\nwave_b=.2+.6*sin(q1-time);",
  "pixel_eqs": "shine=band(rad,2)-(rad+.5)%8*(rad+.5)%2+.2*sin(q1)+.1*sin(above(Q1,q2));\nzoom=shine+.2*sin(above(q2,q1)-rad*sin(q5&time*.75*sin(above(Q5,q6))));\nrot=if(above(q1,q2),.2*sin(q1),-.2*sin(q2));",
