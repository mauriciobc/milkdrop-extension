{
  "name": "Se7enSlasher - Unified Drag Revised",
  "description": "",
  "init_eqs": "time_resettable = 0;\nmusic_time = 0;\n\nrez_rot = 1;",
  "frame_eqs": "wave_thick = -1&(mid+treb)/3; //Yeah. Suitable for percussions.\nwave_additive = -1&bass_att/1.25; //Bassy bass.\n\ntime_resettable += 1/fps;\nif(time_resettable >= .25 && (bass+treb)*0.75 > 1.3, time_resettable = 0, bleh);\nbeat = if (!time_resettable, 1, 0);\n\nrez = if(beat, rand(1)/8.5, rez);\nrez_col_r = if(beat, rand(1), rez_col_r);\nrez_col_g = if(beat, rand(1), rez_col_g);\nrez_col_b = if(beat, rand(1), rez_col_b);\n\nrez_col_r2 = if(beat, rand(1), rez_col_r2);\nrez_col_g2 = if(beat, rand(1), rez_col_g2);\nrez_col_b2 = if(beat, rand(1), rez_col_b2);\n\nrez_col_r3 = if(beat, rand(1), rez_col_r3);\nrez_col_g3 = if(beat, rand(1), rez_col_g3);\nrez_col_b3 = if(beat, rand(1), rez_col_b3);\n\nrez_alpha = if(beat, .5+(rand(1)/2), rez_alpha);\nrez_alpha2 = if(beat, rand(1), rez_alpha2);\nrez_rot = if(beat, .95+(rand(1)/5), rez_rot);\nrez_other = if(beat, rand(1), rez_other);\nrez_mv_x = if(beat, int(rand(30)), rez_mv_x);\nrez_mv_y = if(beat, int(rand(30)), rez_mv_y);\nrez_wavealpha = if(beat, rand(2), rez_wavealpha);\nrez_l = if(beat, .5+(rand(1)/2), rez_l);\nrez_decay = if(beat, .9+rand(1)/10, rez_decay);\n\nob_size = rez;\nob_r = rez_col_r;\nob_g = rez_col_g;\nob_b = rez_col_b;\nob_a = rez_alpha;\nrot = rez_rot;\n\nq1 = rez_other*20;\nq2 = rez_other;\n\n//Borrowed from Unchained's code (and edited a little bit):\nwave_r=.5+.5*sin(rez_col_r2*rez_other+time*2.183);\nwave_g=.5+.5*sin(rez_col_g2*3+time*1.211);\nwave_b=.5+.5*sin(rez_col_b2+time*1.541);\nzoom=.95+.05*q2;\n\necho_zoom = 1 + q2/9.5 + abs(sin(time*(q2*5)))/9.5;\n\nvol = (bass_att+mid_att+treb_att)*0.3;\nmusic_time = music_time + vol*0.4375;\ncx = .5+sin(music_time/9.5)/17.5;\ncy = .5+cos(music_time/9.5)/17.5;\n\nmv_x = rez_mv_x;\nmv_y = rez_mv_y;\nmv_r = rez_col_r3;\nmv_g = rez_col_g3;\nmv_b = rez_col_b3;\nmv_a = rez_alpha2;\nmv_l = rez_l;\nwave_a = rez_wavealpha;\ndecay = rez_decay;",
  "pixel_eqs": "grid_1 = (x*q1)%2 + (y*q1)%2;\nzoom = if(grid_1, 1+abs(sin(time*q2))/8.75, 1);",
