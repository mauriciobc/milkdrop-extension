{
  "name": "yin - 280 - Coming Home (Se7enSlasher's Aspect Ratio Fix)",
  "description": "",
  "frame_eqs": "cont_bass=cont_bass*.93+bass_att*.07;\ncont_mid=cont_mid*.93+mid_att*.07;\ncont_treb=cont_treb*.93+treb_att*.07;\ncont_vol=.993*cont_vol+.0023*(bass+mid+treb);\n\nmax_cont_bass=max(cont_bass,max_cont_bass*.9999);\nmax_cont_mid=max(cont_mid,max_cont_mid);\nmax_cont_treb=max(cont_treb,max_cont_treb);\n\n\nq4=cont_vol;\ndecay=min(1,.8+.05*pow(q4,3));\nq5=-.31415*sin(time*.23+.423+cos(time*.21+1.54));\nc=cos(q5);\ns=sin(q5);\nq6=.5+(.2-.5)*s+(.05-.5)*c;\nq7=.5+(.5-.5)*s+(.1-.5)*c;\nq8=.5+(.8-.5)*s+(.05-.5)*c;\nsunx=if(equal(sunx,0),.25+int(rand(50))/100,sunx);\nsunx=sunx+.001*s*q4;\nsunx=if(equal(sunx,0),sign(s)*.001,sunx);\nq5=sunx;\n\n\nq1=1/aspectx;\nq2=1/aspecty;",
