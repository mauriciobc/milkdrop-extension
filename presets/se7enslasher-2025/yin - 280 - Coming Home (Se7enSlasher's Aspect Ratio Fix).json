  "wave_0_per_frame": "t5=-.31415*sin(time*.23+.423+cos(time*.21+1.54));\nt1=cos(-t5);\nt2=sin(-t5);\nt3=cos(t5);\nt4=sin(t5);\nt8=2*(q4+.2*time-int(q4+.2*time));",
  "wave_0_per_point": "ax=cos(100*sample+43.35+sin(231.54*sample+.543));\nay=sin(431*sample+2.34+cos(443.54*sample+4.23));\naz=sin(546*sample+74.24+sin(524.54*sample+23.987))+ t8;\naz=if(above(az,1),az-2,az);\nc=1/(1-az);\nfx = .5*(1+ax*c);\nox=-.6366*t5+fx;\noy = .5*(1+ay*c);\n\nx=.5+(ox-.5)*t1-(oy-.5)*t2;\ny=.5+(ox-.5)*t2+(oy-.5)*t1;\n\n\nr=1-.5*int(rand(100))/100;\ng=1-.5*int(rand(100))/100;\nb=1-.5*int(rand(100))/100;\n\n// hide occluded stars\nfx=.5+.9*t4;\nfy=.5-1.32*t3;\nviz=above( sqr(x-fx)+sqr(y-fy), 1.2 );\nfx=(q5-.5)*.2+.5;\nviz2=above( sqr(x-fx)+sqr(y-.5), .002 );\na=viz*viz2*pow((az+1)/2,3);",
  "wave_1_per_frame": "// left gauge (bass)\nbass_vol=.93*bass_vol+.07*bass_att;\nt4=min(bass_vol,1.351);\nclip=if(above(bass_vol,1.1),1,0);\nphase=(clip)*(1-lastcip)*frame+clip*lastclip*phase+(1-clip)*lastclip*0;\nt4=if(clip,t4*(.97+int(rand(20))/1000),t4);\nt3=clip;\nt2=phase;\nlastclip=clip;\nt5=-.31415*sin(time*.23+.423+cos(time*.21+1.54));\nt6=.0068;\nt7=.2;\nt8=.05;",
  "wave_1_per_point": "sw0=below(sample,.1429);\nsw1=(1-sw0)*below(sample,.2858);\nsw2=(1-sw0)*(1-sw1)*below(sample,.4286);\nsw3=(1-sw0)*(1-sw1)*(1-sw2)*below(sample,.5718);\nsw4=above(sample,.5717)*below(sample,.7143);\nsw5=above(sample,.7142)*below(sample,.8571);\nsw6=above(sample,.8570);\n\n\n// set transparencies before remapping the sample\na=(below(sample,.14)+above(sample,.15))*(below(sample,.56)+ above(sample,.58))*( below(sample,.71)+above(sample,.72) )*(below(sample,.85)+above(sample,.87));\n\n// normalize sample value to 1\nsample=(sw0*sample+sw1*(sample-.1429) + sw2*(sample-.2858)+sw3*(sample-.4286)+ sw4*(sample-.5717)+sw5*(sample-.7142)+sw6*(sample-.8570))*7;\n\nx=sw0*11*cos(6.2831*sample+4.7715-(q5-.5)*.86-t5);\ny=sw0*11*sin(6.2831*sample+4.7715-(q5-.5)*.86-t5);\n\nx=x+sw1*(-1+10*sample);\ny=y+sw1*(-1+sample);\n\nx=x+sw2*(9-10*sample);\ny=y+sw2*(sample);\n\nx=x-sw3;\ny=y+sw3*(1-2*sample);\nt1=.5*cos(6.2831*sample);\nt2=.5*sin(6.2831*sample);\n\nx=x+sw4*(-6.8+t1);\ny=y+sw4*(-5.8+t2);\n\nx=x+sw5*(8.5+t1);\ny=y+sw5*(-3.5+t2);\n\n\n// rotation (1.26 to -.3)\nangle=(1.26-t4)*3.14;\nt1=cos(angle);\nt2=sin(angle);\nox=x;\noy=y;\nx=(sw0+sw4+sw5)*x+(sw1+sw2+sw3)*(ox*t1-oy*t2);\ny=(sw0+sw4+sw5)*y+(sw1+sw2+sw3)*(ox*t2+oy*t1);\n\nx=x+sw6*(10*cos(1.5*(1-sample)*3.1415));\ny=y+sw6*(10*sin(1.5*(1-sample)*3.1415));\n\nx=x*t6 +t7;\ny=y*t6 +t8;\n\nox=x;\noy=y;\nc=cos(t5);\ns=sin(t5);\nx=.5+(ox-.5)*c-(oy-.5)*s;\ny=.5+(ox-.5)*s+(oy-.5)*c;\n\n// compensate for y-axis pixel-distortion (scale y by 1.38 after all rotations around final center of dial)\nt2=.5+(t7-.5)*s+(t8-.5)*c;\ny=(y-t2)*1.38+t2;\n\nc1=1; // dial colors\nc2=below(sample,.6)+above(sample,.6)*((1-sample)/.4)*.5;\nc3=above(sample,.6)*below(sample,.8)*(sample-.6)*.25/.2;\nc4=pow(sample,4);\n\nc5=.15+.85*pow(1-abs(sample-.5)/.5,3);\nc6=abs(cos(6.2831*(frame-t2)/90));\nr=(sw1+sw2+sw3)*.8+(sw4+sw5)*.5+sw0*c5+sw6*c1;\ng=(sw1+sw2+sw3)*.4+(sw4+sw5)*.5+sw0*c5*(1+t3*(c6-1))+sw6*c2;\nb=(sw1+sw2+sw3)*.2+(sw4+sw5)*.5+sw0*c5*(1+t3*(c6-1))+sw6*c3;\na=sw6*(c4-a)+a;\n\nx = 0.5 + (x-0.5)*q1;\ny = 0.5 + (y-0.5)*q2;",
  "wave_2_per_frame": "// center gauge (mid) size,x,y\nmid_vol=.93*mid_vol+.07*mid_att;\nt4=min(mid_vol,1.351);\nclip=if(above(mid_vol,1.1),1,0);\nphase=(clip)*(1-lastcip)*frame+clip*lastclip*phase+(1-clip)*lastclip*0;\nt4=if(clip,t4*(.97+int(rand(20))/1000),t4);\nt3=clip;\nt2=phase;\nlastclip=clip;\nt5=-.31415*sin(time*.23+.423+cos(time*.21+1.54));\nt6=.008;\nt7=.5;\nt8=.1;",
  "wave_2_per_point": "sw0=below(sample,.1429);\nsw1=(1-sw0)*below(sample,.2858);\nsw2=(1-sw0)*(1-sw1)*below(sample,.4286);\nsw3=(1-sw0)*(1-sw1)*(1-sw2)*below(sample,.5718);\nsw4=above(sample,.5717)*below(sample,.7143);\nsw5=above(sample,.7142)*below(sample,.8571);\nsw6=above(sample,.8570);\n\n\n// set transparencies before remapping the sample\na=(below(sample,.14)+above(sample,.15))*(below(sample,.56)+ above(sample,.58))*( below(sample,.71)+above(sample,.72) )*(below(sample,.85)+above(sample,.87));\n\n// normalize sample value to 1\nsample=(sw0*sample+sw1*(sample-.1429) + sw2*(sample-.2858)+sw3*(sample-.4286)+ sw4*(sample-.5717)+sw5*(sample-.7142)+sw6*(sample-.8570))*7;\n\nx=sw0*11*cos(6.2831*sample+4.7715-(q5-.5)*.86-t5);\ny=sw0*11*sin(6.2831*sample+4.7715-(q5-.5)*.86-t5);\n\nx=x+sw1*(-1+10*sample);\ny=y+sw1*(-1+sample);\n\nx=x+sw2*(9-10*sample);\ny=y+sw2*(sample);\n\nx=x-sw3;\ny=y+sw3*(1-2*sample);\nt1=.5*cos(6.2831*sample);\nt2=.5*sin(6.2831*sample);\n\nx=x+sw4*(-6.8+t1);\ny=y+sw4*(-5.8+t2);\n\nx=x+sw5*(8.5+t1);\ny=y+sw5*(-3.5+t2);\n\n\n// rotation (1.26 to -.3)\nangle=(1.26-t4)*3.14;\nt1=cos(angle);\nt2=sin(angle);\nox=x;\noy=y;\nx=(sw0+sw4+sw5)*x+(sw1+sw2+sw3)*(ox*t1-oy*t2);\ny=(sw0+sw4+sw5)*y+(sw1+sw2+sw3)*(ox*t2+oy*t1);\n\nx=x+sw6*(10*cos(1.5*(1-sample)*3.1415));\ny=y+sw6*(10*sin(1.5*(1-sample)*3.1415));\n\nx=x*t6 +t7;\ny=y*t6 +t8;\n\nox=x;\noy=y;\nc=cos(t5);\ns=sin(t5);\nx=.5+(ox-.5)*c-(oy-.5)*s;\ny=.5+(ox-.5)*s+(oy-.5)*c;\n\n// compensate for y-axis pixel-distortion (scale y by 1.38 after all rotations around final center of dial)\nt2=.5+(t7-.5)*s+(t8-.5)*c;\ny=(y-t2)*1.38+t2;\n\nc1=1; // dial colors\nc2=below(sample,.6)+above(sample,.6)*((1-sample)/.4)*.5;\nc3=above(sample,.6)*below(sample,.8)*(sample-.6)*.25/.2;\nc4=pow(sample,4);\n\nc5=.15+.85*pow(1-abs(sample-.5)/.5,3);\nc6=abs(cos(6.2831*(frame-t2)/90));\nr=(sw1+sw2+sw3)*.8+(sw4+sw5)*.5+sw0*c5+sw6*c1;\ng=(sw1+sw2+sw3)*.4+(sw4+sw5)*.5+sw0*c5*(1+t3*(c6-1))+sw6*c2;\nb=(sw1+sw2+sw3)*.2+(sw4+sw5)*.5+sw0*c5*(1+t3*(c6-1))+sw6*c3;\na=sw6*(c4-a)+a;\n\nx = 0.5 + (x-0.5)*q1;\ny = 0.5 + (y-0.5)*q2;",
  "wave_3_per_frame": "// right gauge (treb)\ntreb_vol=.93*treb_vol+.07*treb_att;\nt4=min(treb_vol,1.351);\nclip=if(above(treb_vol,1.1),1,0);\nphase=(clip)*(1-lastcip)*frame+clip*lastclip*phase+(1-clip)*lastclip*0;\nt4=if(clip,t4*(.97+int(rand(20))/1000),t4);\nt3=clip;\nt2=phase;\nlastclip=clip;\nt5=-.31415*sin(time*.23+.423+cos(time*.21+1.54));\nt6=.0068;\nt7=.8;\nt8=.05;",
  "wave_3_per_point": "sw0=below(sample,.1429);\nsw1=(1-sw0)*below(sample,.2858);\nsw2=(1-sw0)*(1-sw1)*below(sample,.4286);\nsw3=(1-sw0)*(1-sw1)*(1-sw2)*below(sample,.5718);\nsw4=above(sample,.5717)*below(sample,.7143);\nsw5=above(sample,.7142)*below(sample,.8571);\nsw6=above(sample,.8570);\n\n\n// set transparencies before remapping the sample\na=(below(sample,.14)+above(sample,.15))*(below(sample,.56)+ above(sample,.58))*( below(sample,.71)+above(sample,.72) )*(below(sample,.85)+above(sample,.87));\n\n// normalize sample value to 1\nsample=(sw0*sample+sw1*(sample-.1429) + sw2*(sample-.2858)+sw3*(sample-.4286)+ sw4*(sample-.5717)+sw5*(sample-.7142)+sw6*(sample-.8570))*7;\n\nx=sw0*11*cos(6.2831*sample+4.7715-(q5-.5)*.86-t5);\ny=sw0*11*sin(6.2831*sample+4.7715-(q5-.5)*.86-t5);\n\nx=x+sw1*(-1+10*sample);\ny=y+sw1*(-1+sample);\n\nx=x+sw2*(9-10*sample);\ny=y+sw2*(sample);\n\nx=x-sw3;\ny=y+sw3*(1-2*sample);\nt1=.5*cos(6.2831*sample);\nt2=.5*sin(6.2831*sample);\n\nx=x+sw4*(-6.8+t1);\ny=y+sw4*(-5.8+t2);\n\nx=x+sw5*(8.5+t1);\ny=y+sw5*(-3.5+t2);\n\n\n// rotation (1.26 to -.3)\nangle=(1.26-t4)*3.14;\nt1=cos(angle);\nt2=sin(angle);\nox=x;\noy=y;\nx=(sw0+sw4+sw5)*x+(sw1+sw2+sw3)*(ox*t1-oy*t2);\ny=(sw0+sw4+sw5)*y+(sw1+sw2+sw3)*(ox*t2+oy*t1);\n\nx=x+sw6*(10*cos(1.5*(1-sample)*3.1415));\ny=y+sw6*(10*sin(1.5*(1-sample)*3.1415));\n\nx=x*t6 +t7;\ny=y*t6 +t8;\n\nox=x;\noy=y;\nc=cos(t5);\ns=sin(t5);\nx=.5+(ox-.5)*c-(oy-.5)*s;\ny=.5+(ox-.5)*s+(oy-.5)*c;\n\n// compensate for y-axis pixel-distortion (scale y by 1.38 after all rotations around final center of dial)\nt2=.5+(t7-.5)*s+(t8-.5)*c;\ny=(y-t2)*1.38+t2;\n\nc1=1; // dial colors\nc2=below(sample,.6)+above(sample,.6)*((1-sample)/.4)*.5;\nc3=above(sample,.6)*below(sample,.8)*(sample-.6)*.25/.2;\nc4=pow(sample,4);\n\nc5=.15+.85*pow(1-abs(sample-.5)/.5,3);\nc6=abs(cos(6.2831*(frame-t2)/90));\nr=(sw1+sw2+sw3)*.8+(sw4+sw5)*.5+sw0*c5+sw6*c1;\ng=(sw1+sw2+sw3)*.4+(sw4+sw5)*.5+sw0*c5*(1+t3*(c6-1))+sw6*c2;\nb=(sw1+sw2+sw3)*.2+(sw4+sw5)*.5+sw0*c