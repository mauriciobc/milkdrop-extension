h*(-1.5-1.5*s)                +i*(3.+1.5*s)                   +j*(7.5+3*s)                +k*100;\nxL=h*(-1.5)                      +i*-1.5                         +j*(6.+2.5*s)               +k*100;\nyL=h*(1.5+1.5*s)                 +i*(1.5+1.5*s)                  +j*(-1.5)                   +k*100;\nxM=h*-1.5                        +i*1.5                          +j*(3.+1.5*s)               +k*(6+1.5*s);\nyM=h*(1.5+3*s)                   +i*(4.5+3*s)                    +j*(-1.5-s)                 +k*(4.5+s);\nxN=h*-1.15                       +i*(3.45+2.3*s)                 +j*1.15                     +k*100;\nyN=h*(1.5+3*s)                   +i*(-4.5-3*s)                   +j*(7.5+3*s)                +k*100;\nxO=h*(1.5*sin(1.57*s))           +i*(1.5*sin(1.57*s))            +j*(1.5*sin(1.57*s))        +k*(1.5*sin(1.57*s));\nyO=h*(1.5*cos(1.57*s))           +i*(1.5*cos(1.57*s))            +j*(1.5*cos(1.57*s))        +k*(1.5*cos(1.57*s));\nxP=h*(-1-2.5*sin(1.57*s))        +i*(-1-2.5*sin(1.57*s))         +j*(-1.3)                   +k*-1.3;\nyP=h*(.6+.8*cos(1.57*s))         +i*(.6+.8*cos(1.57*s))          +j*(4.5+1.5*s)              +k*(4.5+1.5*s);\nxQ=h*(1.5*sin(2.1*s))            +i*(1.5*sin(2.1*s))             +j*(1.5*sin(2.1*s))         +k*(2.25+.5*s);\nyQ=h*(1.5*cos(2.1*s))            +i*(1.5*cos(2.1*s))             +j*(1.5*cos(2.1*s))         +k*(-4-.75*s);\nxR=h*(-.5-2*sin(1.57*s))         +i*(-.5-2*sin(1.57*s))          +j*(4.2+1.5*s)              +k*-1.1;\nyR=h*(.7+.8*cos(1.57*s))         +i*(.7+.8*cos(1.57*s))          +j*(-3.9-1.2*s)             +k*(10.5+3*s);\nxS=h*(.75+2*sin(1.3*s))          +i*(.75+2*sin(1.3*s))           +j*(-1.25+2*sin(-.5+1.3*s)) +k*(-1.25+2*sin(-.5+1.3*s));\nyS=h*(.75+.75*cos(1.3*s))        +i*(.75+.75*cos(1.3*s))         +j*(-.6+.75*cos(-.5+1.3*s)) +k*(-.6+.75*cos(-.5+1.3*s));\nxT=h*0                           +i*0                            +j*(7.5+3*s);               +k*100;\nyT=h*(1.5+1.5*s)                 +i*(1.5+1.5*s)                  +j*1.5                      +k*100;\nxU=h*(1.25*sin(1.57+1.57*s))     +i*(1.25*sin(1.57+1.57*s))      +j*(-1.25)                  +k*1.25;\nyU=h*(-.5-1.25*cos(1.57+1.57*s)) +i*(-.5-1.25*cos(1.57+1.57*s))  +j*(4.75+1.75*s)            +k*(6.5+1.75*s);\nxV=h*(1.25+.5*s)                 +i*(1.25+.5*s)                  +j*(1.5+.75*s)              +k*(1.5+.75*s);\nyV=h*(1.5+1.5*s)                 +i*(1.5+1.5*s)                  +j*(-4.5-1.5*s)             +k*(-4.5-1.5*s);\nxX=h*(1.25+1.25*s)               +i*(1.25+1.25*s)                +j*(3.5+1.25*s)             +k*(3.5+1.25*s);\nyX=h*(1.5+1.5*s)                 +i*(1.5+1.5*s)                  +j*(-4.5-1.5*s)             +k*(-4.5-1.5*s);\nxW=h*-1.5                        +i*1.5                          +j*(3.+1.5*s)               +k*(6+1.5*s);\nyW=h*(1.5+3*s)                   +i*(4.5+3*s)                    +j*(1.5+s)                  +k*(-4.5-s);\nxY=h*0                           +i*(3+1.5*s)                    +j*(3+1.5*s)                +k*100;\nyY=h*(.5+2*s)                    +i*(2.5+s)                      +j*(-1.5-s)                 +k*100;\nxZ=h*(1+2.25*s)                  +i*(3.25+2.25*s)                +j*(5.5+2.25*s)             +k*100;\nyZ=h*1.5                         +i*(4.5+3*s)                    +j*-1.5                     +k*100;\nxEm=h*0                          +i*0                            +j*0                        +k*100;\nyEm=h*(1.6+s)                    +i*(1.6+s)                      +j*(-1.4+.1*s)              +k*100;\nxQm=h*(sin(1.57*s))              +i*(sin(3.14+1.57*s))           +j*(3+s)                    +k*0;\nyQm=h*(.5+cos(1.57*s))           +i*(.5+cos(3.14+1.57*s))        +j*(2.5+s)                  +k*(-1.4+.1*s);\nx1=h*0                           +i*0                            +j*0                        +k*(1.2+.6*s);\ny1=h*(1.5+s)                     +i*(1.5+s)                      +j*(1.5+s)                  +k*(3+.6*s);\nx2=h*(-.5+1.25*sin(1+2*s))       +i*(-.25-1.25*sin(1+2*s))       +j*(3+1.5*s)                +k*(8.5+2.5*s);\ny2=h*(.5+1.*cos(1+2*s))          +i*(.25+1.*cos(1+2*s))          +j*(.25+.5*s)               +k*(-1.5);\nx3=h*(1.5*sin(.5+1.57*s))        +i*(-.25+1.5*sin(3.5+1.57*s))   +j*(-.25+1.5*sin(-1+1.57*s))+k*(1.5*sin(2.5+1.57*s));\ny3=h*(1.5*cos(.5+1.57*s))        +i*(.5+1.*cos(3.5+1.57*s))      +j*(-1+1.*cos(-1+1.57*s))   +k*(-.25+1.5*cos(2.5+1.57*s));\nx4=h*.5                          +i*(1.5+1.5*s)                  +j*(7.5+3*s)                +k*(111);\ny4=h*(1.75+3.5*s)                +i*(3.+1.5*s)                   +j*(0)                      +k*(111);\nx5=h*(-1.-2*sin(1.57*s))         +i*(-1.-2*sin(1.57*s))          +j*(-1)                     +k*(7.25+2*s);\ny5=h*(-.75+.75*cos(1.57*s))      +i*(-.75+.75*cos(1.57*s))       +j*(4.75+1.5*s)             +k*(1.5);\nx6=h*(1.25*sin(3.14*s))          +i*(1.25*sin(3.14*s))           +j*(.1+1.5*sin(-.5+2.5*s))  +k*(111);\ny6=h*(-.5+cos(3.14*s))           +i*(-.5+cos(3.14*s))            +j*(.25+1.5*cos(-.5+2.5*s))  +k*(111);\nx7=h*(1.5+2.5*s)                 +i*(2+s)                        +j*(2.3+s)               +k*100;\ny7=h*(1.5)                       +i*(2.5+1.5*s)                  +j*(3+1.5*s)                +k*100;\nx8=h*(1.25*sin(-.2+2.7*s))       +i*(1.25*sin(-.75+2.7*s))       +j*(1.25*sin(-1+2.7*s))     +k*(1.25*sin(-1.5+2.7*s));\ny8=h*(.75+.75*cos(-.2+2.7*s))    +i*(.75+.75*cos(-.75+2.7*s))    +j*(-.75-.75*cos(-1+2.7*s))  +k*(-.75-.75*cos(-1.5+2.7*s));\nx9=h*(1.25*sin(3.14*s))          +i*(1.25*sin(3.14*s))           +j*(-.25+1.5*sin(.6+2.5*s))  +k*(111);\ny9=h*(.5+cos(3.14*s))            +i*(.5+cos(3.14*s))             +j*(-.25-1.5*cos(.6+2.5*s))  +k*(111);\nx0=h*100                         +i*100                          +j*100                       +k*100;\ny0=h*100                         +i*100                          +j*100                       +k*100;\n\nindex=index+1;);",
