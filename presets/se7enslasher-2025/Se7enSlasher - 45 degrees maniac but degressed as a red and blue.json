  "init_eqs": "leafset = 3;",
  "frame_eqs": "wave_r = 0.5 + 0.5*sin(1.63*time);\nwave_g = 0.5 + 0.5*sin(4.1*time);\nwave_b = -1 + (1-wave_r + 1-wave_g);\nwarp = 0;\npfthresh = above(bass_att,pfthresh)*3+(1-above(bass_att,pfthresh))*((pfthresh-1.34)*0.95+1.34);\npfdx_r = equal(pfthresh,3)*0.015*sin(5*time)+(1-equal(pfthresh,3))*pfdx_r;\npfdy_r = equal(pfthresh,3)*0.015*sin(6*time)+(1-equal(pfthresh,3))*pfdy_r;\nq1 = wave_r;\nq2 = wave_g;\nq3 = wave_b;\n\nob_r = 1-abs(q1)*0.75;\nob_g = 1-abs(q2)*0.743;\nob_b = 1-abs(q3)*0.75;\necho_zoom = echo_zoom - min(max(0.75,50*pfdx_r),1);\n\necho_orient = echo_orient + 16*pfdy_r;\n\ndx = dx + 12.1*pfdx_r;\ndy = dy + 12.1*pfdy_r;\n//ib_a = ib_a + min(0.5,0.5-abs(dx+dy));\n\ncog = ocog+0.005*(bass+bass_att+(bass*bass_att)-2);\nocog = below(cog,30000)*cog;\nq4 = cog;\nob_r = q2;\nob_g = q3;\nob_b = q1;\nrcog = orcog + 0.52*(rand(100)*0.01);\norcog = below(rcog,20000)*rcog;\nq5 = rcog;\n//ib_size = ib_size + 0.009*treb_att*tan(q4);\n//ob_size = ob_size + 0.009*bass_att*cos(q4);\n//ob_a = ob_a + min(0.5,0.5-abs(q4-q5));\nib_r = 1-abs(q1)*sin(q4);\nib_g = 0.75*cos(q4);\nib_b = 1-abs(q3)*cos(q5);",
  "pixel_eqs": "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);\ndx_r = equal(thresh,2)*0.015*sin(5*time)+(1-equal(thresh,2))*dx_r;\ndy_r = equal(thresh,2)*0.0152*sin(6*time)+(1-equal(thresh,2))*dy_r;\ntg1 = abs(sin(time));\ntg2 = 4*dy_r*above(tg1,0.5) + 4*dx_r*below(tg1,0.5);\ntg3 = if(equal(thresh,2),tg2,tg3);\n\nladder = abs(sin(1*time));\nleaf = 5*below(ladder,0.2) + 8*above(ladder,0.2)*below(ladder,0.39) +\n12*above(ladder,0.4)*below(ladder,0.6) + 18*above(ladder,0.6)*below(ladder,0.8) +\n24*above(ladder,0.8);\nleafset = if(equal(thresh,2), leaf, leafset);\n\nzoom = zoom + 0.05*(0.75-sin(leafset*5))*(1-rad);\nzoom = zoom - abs(0.051*(0.743-cos(4*ang)));\n\nzoom = zoom + tg3*tan(4*q4)*below(zoom,0.22)*above(zoom,-0.22);\n\nzoom = zoom + 0.00979*(sin(10*ang) + sin(sin(time*2*sin(time)*rad))*0.31 - cos(rad)*0.1);\nrot = rot + 0.08*abs(0.746-rad)*sin(2.2*(0.5-rad)+5.7*sin(0.1*time));\nsx = sx + 0.01*(0.99*1-rad)*sin(0.733*time)*below(sin(time),0);\nsy = sy + 0.01*(0.99*1-rad)*cos(0.953*time)*above(sin(time),0);\nzoom = zoom - 0.0152*(0.52*abs(3)-rad)*below(rad,1.54);",
