  "shape_0_init": "t1 = rand(100)*0.01;\nt2 = rand(100)*0.01;",
  "shape_0_per_frame": "// Loadus & Geiss custom shape design\n\nang = q4*(0.13 + 0.1*t1);\nrad = rad * (0.5 + 0.2*t2);\nr = min(1,max(0,r + 0.2*sin(time*0.417 + 1)));\ng = min(1,max(0,g + 0.2*sin(time*0.391 + 2)));\nb = min(1,max(0,b + 0.2*sin(time*0.432 + 4)));\nr2 = min(1,max(0,r2 + 0.2*sin(time*0.657 + 3)));\ng2 = min(1,max(0,g2 + 0.2*sin(time*0.737 + 5)));\nb2 = min(1,max(0,b2 + 0.2*sin(time*0.884 + 6)));",
  "shape_1_init": "t1 = rand(100)*0.01;\nt2 = rand(100)*0.01;",
  "shape_1_per_frame": "// Loadus & Geiss custom shape design\n\nx = x + 0.05*sin(time*1.05+33);\ny = y + 0.029*sin(time*1.09+24);\nang = q4*(0.2 + 0.1*t1);\nrad = rad * (0.87 + 0.19*t2);\nr = q3;\ng = q1;\nb = q2;\n\n//r = min(1,max(0,r + 0.1*sin(time*0.417 + 1)));\n//g = min(1,max(0,g + 0.1*sin(time*0.391 + 2)));\n//b = min(1,max(0,b + 0.1*sin(time*0.432 + 4)));\nr2 = min(1,max(0,r2 + 0.1*sin(time*0.457 + 3)));\ng2 = min(1,max(0,g2 + 0.1*sin(time*0.437 + 5)));\nb2 = min(1,max(0,b2 + 0.1*sin(time*0.484 + 6)));",
  "shape_2_init": "t1 = rand(100)*0.01;\nt2 = rand(100)*0.01;",
  "shape_2_per_frame": "// Loadus & Geiss custom shape design\n\nx = x + 0.05*sin(time*0.167+24);\ny = y + 0.03*sin(time*0.228+28);\nang = q4*(0.5 + 0.1*t1);\nrad = rad * (0.91 + 0.19*t2);\nr = q1;\ng = q3;\nb = q2;\n\n//r = min(1,max(0,r + 0.1*sin(time*0.417 + 1)));\n//g = min(1,max(0,g + 0.1*sin(time*0.391 + 2)));\n//b = min(1,max(0,b + 0.1*sin(time*0.432 + 4)));\nr2 = min(1,max(0,r2 + 0.1*sin(time*0.457 + 3)));\ng2 = min(1,max(0,g2 + 0.1*sin(time*0.437 + 5)));\nb2 = min(1,max(0,b2 + 0.1*sin(time*0.484 + 6)));",
