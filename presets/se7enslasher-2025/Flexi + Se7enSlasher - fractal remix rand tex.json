  "wave_0_init": "t2 = 0;\nt3 = 0;\nt4 = 0;\ncl = 0;",
  "wave_0_per_frame": "t8 = 1;",
  "wave_0_per_point": "t8 = -t8;\nx1 = q1;\nx2 = (xx-0.5 + sin(q2)*0.3)*2.2*0.355 + ox + 0.5;\ny2 = 0.787;\n\nd= t8*(sample*0.01+0.03);\ny = (1-sample)*y2 + sample + d*(x1-x2);\nx = sample*x1 + (1-sample)*x2 + d*(1-y2);\n\npi3 = 3.1415*2*0.3333;\nt = -q3*300+sample*asin(1)*4.01;\nc=1;\n//r = sin(t)*c;\n//g = sin(t+pi3)*c;\n\n//b = sin(t-pi3)*c;\n\n\nr = if(above(r,1),1,r);\nr = if(below(r,0),0,r);\ng = if(above(g,1),1,g);\ng = if(below(g,0),0,g);\nb = if(above(b,1),1,b);\nb = if(below(b,0),0,b);\n\n\nxx = q1;\nox = (q4-0.5)*0.2;",
  "wave_1_init": "t2 = 0;\nt3 = 0;\nt4 = 0;\ncl = 0;",
