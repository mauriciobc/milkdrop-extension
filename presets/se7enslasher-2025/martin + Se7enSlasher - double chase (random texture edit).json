  "frame_eqs": "dec_m=1-4/fps;dec_s=1-1/fps;\n\natt_b=att_b*dec_m + bass*(1-dec_m);\natt_m=att_m*dec_m + mid *(1-dec_m);\natt_t=att_t*dec_m + treb*(1-dec_m);\nvol=bass+mid+treb;\ndec=if(vol>vol_,dec_m,dec_s);\nvol_=dec*vol_+(1-dec)*vol;\n\nibass =int(4*max(0,bass-att_b));\nimid  =int(4*max(0,mid -att_m));\nitreb =int(4*max(0,treb-att_t));\n\n\nadd+=(mid>mid_att)/fps;\nif (add>1, add=0; ttmax=2*int(rand(16)+1); mod=2+int(rand(20)); adiv=int(rand(3))+2,0);\ntt=frame%ttmax;\n\nadd2+=pow(mid-mid_att,2)/fps;\nif (add2>2,add2=0;liq=int(rand(2)); if(rand(10)>7,sttt=1,sttt=0);\nif(rand(10)>3,\nif ((cpx>0) || (cpy>0),\ncpx=cpy=cp=0,\ncpx=int(rand(2)); cpy=int(rand(2)); cp=rand(0.8)),0),0);\n\nif (sttt,tt=1;ttmax=2,0);\nds_b=if(ibass==0,1,3*bass_att)*0.5/nshapes*(bass_att>0.3)*1;\nds_m =if(imid ==0,1,mid_att)*40/nshapes*(mid_att>0.7)*(tt%mod)/sqrt(mod*ttmax);;\nds_t=if(itreb==0,1,treb_att)*1/nshapes;\n\nm=0; n=0; ran1=rand(1);\nloop (3,\nloop (nshapes,\nif (m==0,\narg = (dir_b+n/nshapes*ibass)*pi/2;\nds=ds_b;\n,\nif (m==1,\narg = (dir_m+(n-m*nshapes)/nshapes*imid)*pi/adiv*tt;\nds=ds_m;\n,\narg = (dir_b+n/nshapes*ibass)*pi/2;\nds=ds_b;));\n\ni=((n+nshapes)%nshapes  +m*nshapes)*10;\nj=((n-1+nshapes)%nshapes+m*nshapes)*10;\ngmegabuf(i)  =gmegabuf(j)   +sin(arg)*ds/fps;\ngmegabuf(i+1)=gmegabuf(j+1) +cos(arg)*ds/fps;\nif (ran1>0.05,\ngmegabuf(i+6)=0.01; //rad\ngmegabuf(i+7)=6; //sides\n,\ngmegabuf(i+6)=0.02*(n%20<3); //rad\ngmegabuf(i+7)=6; //sides\n);\nn+=1;);\nm+=1;\n);\n\nm=0; n=0;\nloop (3,\nloop (nshapes,\nlim=1;\ni=n*10;\nif(gmegabuf(i)  >lim, gmegabuf(i)=-lim;gmegabuf(i+1)-=0.03,0);\nif(gmegabuf(i)  <-lim, gmegabuf(i)=lim; ;gmegabuf(i+1)+=0.03,0);\nlim= lim/aspecty;\nif(gmegabuf(i+1)>lim, gmegabuf(i+1)=-lim;;gmegabuf(i)-=0.03,0);\nif(gmegabuf(i+1)<-lim, gmegabuf(i+1)=lim;;gmegabuf(i)+=0.03,0);\nn+=1;);\nm+=1;\n);\n\ndir_b= int(dir_b +ibass)%128;\ndir_m= int(dir_m +imid) %128;\ndir_t= int(dir_t +itreb)%128;\n\nreg32=aspecty;\nwarp=0;zoom=1;sx=sy=1;\nq1=reg60;\nq2=reg61;\nq10=vol_/2;\nq11=liq;\n\nq5=cpx;\nq6=cpy;\ncp_=cp_*dec_s+(1-dec_s)*cp;\nq7=cp_;\n\n//q5=0;q6=1;q7=0.931;\nmonitor = add2;",
