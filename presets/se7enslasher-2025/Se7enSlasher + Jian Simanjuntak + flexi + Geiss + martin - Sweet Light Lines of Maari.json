  "init_eqs": "intfrac = int(rand(20));\n\nintnumerator1 = int(rand(2));\nintnumerator2 = int(rand(2));",
  "frame_eqs": "dec_med = 1- .2*30/fps;\ndec_slow = 1-.05*30/fps;\n\nbeat = max (max (bass, mid), treb);\navg = avg*dec_slow + beat*(1-dec_slow);\nis_beat = above(beat, .2*avg+peak) * above (time, t0+.1);\nt0 = is_beat*time + (1-is_beat)*t0;\npeak = is_beat * beat + (1-is_beat)*peak*dec_med;\nindex = (index + is_beat) %16;\n\nq27 = index;\nq22 = peak;\npeak_ = dec_med*peak_ + (1-dec_med)*peak;\n\ntrig = is_beat * bnot(index%4);\ncount = count + trig;\nrott = rott*dec_med + (1-dec_med) * count*3.14/2;\nq1 = cos(rott);\nq2 = sin(rott);\n\n\nma = ma + (peak_-0)/fps*4*above(peak_,0);\nmx=mx*dec_slow+(1-dec_slow)*cos(ma);\nmy=my*dec_slow+(1-dec_slow)*sin(ma*q1);\nq15 = mx/2 ;\nq16 = my/2 ;\nq17 = ma;\n\nang1 = ang1 + 8*bass*above(bass,1)/fps*q1;\nq18 = ang1;\n\nq32 = aspecty;\nmonitor = q1;\n\n//My moving flexi's fabric code\nq1 = sin(time)/10+.25;\nq2 = 0;\n\nq3 = 0;\nq4 = sin(time)/10+.25;\n\nq5 = -(sin(time)/10+.25);\nq6 = 0;\n\nq7 = 0;\nq8 = -(sin(time)/10+.25);\n\n//Initializations\nq9 = intfrac;\nq10 = intnumerator1;\nq11 = intnumerator2;\n\n//My Slow-Decrease Bass Code\noldbass += bass*1.75;\noldbass = if (oldbass < bass, oldbass, oldbass/=1.05);\nq12 = oldbass;\n\n//My Beat Decision Code\nbeatbool = if(above(bass, 1.525), 1, 0);\nmidbool = if(above(mid, 1.25), 1, 0);\ntrebbool = if (above(treb, 1.6), 1, 0);\n\nchange = if(beatbool==1, 1, if(midbool==1, 2, if(trebbool==1, 3, change)));\nq13 = change;",
