  "wave_0_init": "t1 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt2 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt3 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt4 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt5 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt6 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt7 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt8 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\n",
  "wave_0_per_frame": "t2 = t2 + bass_att;",
  "wave_0_per_point": "\n\n\nox = 0.5+value1;\noy = 0.3+value2;\noz = -30 + sample * 35;\n\nxang = 0;\nyang = 0;\nzang = 0;\nfov = 1.2;\n\nb = 1; g = .5; r = 0.3;\na = 1;\n// Rotation um x,y,z\n\nmx = ox*cos(zang) - oy*sin(zang);\nmy = ox*sin(zang) + oy*cos(zang);\n\nox = mx;\noy = my;\nmx = ox*cos(yang) + oz*sin(yang);\nmz = - ox*sin(yang) + oz*cos(yang);\nox = mx;\noz = mz;\nmy = oy*cos(xang) - oz*sin(xang);\nmz = oy*sin(xang) + oz*cos(xang);\noy = my;\noz = mz;\n\noz = oz - 6;\nx = ox*fov/oz +0.5;\ny = oy*fov/oz + 0.5;",
  "wave_1_init": "t1 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt2 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt3 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt4 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt5 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt6 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt7 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt8 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\n",
  "wave_1_per_frame": "trel = q1-.0;\nt1 = int(trel)/2;\nt2 = trel - int(trel);",
  "wave_1_per_point": "k1 = (sample*512) % 8;\n\nt1 = equal (k1,0)*((t1 * 61 + 27) % 4096)\n+ (1-equal(k1,0))*t1;\n\nexc = 1+rand(5);\nampl = sample*sqrt(t2) * (1+exc);\n\nf1 = q4*ampl* sin(t1*6.28/4096);\nf2 = q4*ampl* cos(t1*6.28/4096);\n\nx = q2 + k1* f1 ;\ny = q3 + k1* f2;\n\na = equal(k1,6) + equal (k1,0);\n\nr = 1;\nb = equal (k1,0);\ng = .6* (1+.6*equal (k1,0))  ;\na = a * q5 * (1-0*t2*t2);\n//a = 0;\n",
  "wave_2_init": "t1 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt2 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt3 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt4 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt5 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt6 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt7 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\nt8 = 1 + (rand(101)*.01 - rand(101)*.01)*.3;\n",
  "wave_2_per_frame": "trel = q1-.33;\nt1 = int(trel)/3;\nt2 = trel - int(trel);\n\n\n",
  "wave_2_per_point": "k1 = (sample*512) % 8;\n\nt1 = equal (k1,0)*((t1 * 61 + 27) % 4096)\n+ (1-equal(k1,0))*t1;\n\nampl = sample*sqrt(t2);\n\nf1 = q4*ampl* sin(t1*6.28/4096);\nf2 = q4*ampl* cos(t1*6.28/4096);\n\nx = q2 + k1* f1 ;\ny = q3 + k1* f2;\n\na = equal(k1,6) + equal (k1,0);\n\nr = 1;\nb = equal (k1,0);\ng = .6* (1+.6*equal (k1,0));\na = a * q5 * (1-0*t2*t2);\n//a = 0;",
  "wave_3_per_frame": "trel = q1-.66;\nt1 = int(trel);\nt2 = trel - int(trel);",
  "wave_3_per_point": "k1 = (sample*512) % 8;\n\nt1 = equal (k1,0)*((t1 * 61 + 27) % 4096)\n+ (1-equal(k1,0))*t1;\n\nampl = sample*sqrt(t2);\n\nf1 = q4*ampl* sin(t1*6.28/4096);\nf2 = q4*ampl* cos(t1*6.28/4096);\n\nx = q2 + k1* f1 ;\ny = q3 + k1* f2;\n\na = equal(k1,6) + equal (k1,0);\n\nr = 1;\nb = equal (k1,0);\ng = .6* (1+.6*equal (k1,0));\na = a * q5 * (1-0*t2*t2);\n//a = 0;",
  "shape_1_per_frame": "k1 = instance/num_inst-.5;\n\nx0 = .5+ .4*q2;\ny0 = .5+ .4*q1;\nx =  x0+2*k1*cos(q18) ;\ny =  y0+2*k1*sin(-q18) ;\n\ntrel = time;\nr = .5 + .5*sin(q27+k1*3+trel);\ng = .5 + .5*sin(q27*2+k1*2+trel);\nb = .5 + .5*sin(q27*3+k1*1+trel);\nr2 = r;\ng2 = g;\nb2 = b;\n\nrad = .04;",
  "shape_2_per_frame": "k1 = instance/num_inst-.5;\n\nx0 = .5+ .4*q1;\ny0 = .5+ .4*q2;\nx =  x0+2*k1*cos(q18) -.1;\ny =  y0+2*k1*sin(q18) ;\n\ntrel = time;\n//r = .5 + .5*sin(q27+k1*3+trel);\n//g = .5 + .5*sin(q27*2+k1*2+trel);\n//b = .5 + .5*sin(q27*3+k1*1+trel);\n\nr = 1;\ng = 0;\nb = bass_att/4.5;\n\nr2 = r;\ng2 = g;\nb2 = b;",
  "shape_3_per_frame": "t0 = time/3;\nx = t0 - int(t0);\n\n//y = q2/30+0.8;\n\ny1 = .8 + bass+treb+mid;\ny = (y1-y0)/200 + .8;\ny0 = y1;\n\n\nb_ = b_*.9 +bass;\nm_ = m_*.9 +mid;\nt_ = t_*.9 +treb;\n\ny = .8 + (bass+mid+treb)/150;\ny = 0.8 + (q2+q1)/30;\n//f.0 = 3;"
