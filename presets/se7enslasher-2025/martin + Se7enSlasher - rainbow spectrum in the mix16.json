  "wave_0_per_frame": "t1 = 0; t2 = 1000;",
  "wave_0_per_point": "if (reg05,\nsig = log(1+(value1+value2)/reg20) * (1+exp(-16*sample));\ndec = if (sig > gmegabuf(t1),reg00,reg01);\ngmegabuf(t1) *= dec;\ngmegabuf(t1) += (1-dec)*sig;\nreg19 = max (reg19, gmegabuf(t1));\n\nt3 = t1+2000;\ngmegabuf(t3)=max(0,if(gmegabuf(t1)>gmegabuf(t2),1,gmegabuf(t3)-1/fps));\n\nt2 = t1+1000;\ndif = if (gmegabuf(t3)>0,0,2/fps);\ndif = 0.5/fps;\ngmegabuf(t2)=max (gmegabuf(t2)-dif,gmegabuf(t1));\n\n,0);\n\nt1 += 1;\nx=sample; y=0.5+value1*.1;",
  "wave_1_per_frame": "t1 = 0;",
  "wave_1_per_point": "step = 12;\nfrac = (t1%step);\n\nslot = int(t1/7);\n\nrad1 = if (frac<3, 0, if (frac>step-4, gmegabuf(slot)*0.2, gmegabuf(slot)*0.2))+0.2;\n\nang1 = slot*0.2;\n\nx = 0.5 + cos(ang1)*rad1;\ny = 0.5 + sin(ang1)*rad1;\n\na = (frac>1) * (frac<step-2);\n\nt1 += 1;",
  "shape_1_per_frame": "x = 1-rad/2;\ny = 1-instance/num_inst;\nbias = -0.05;\nr = max(0,gmegabuf(instance)/4+bias);\nr = 1-exp(-r);\nr2 = r;\n\ndec = 1-2/fps;\ng = max(0,gmegabuf (1000+instance)/4+bias);\ng=1-exp(-g);\ng2=g;\n\nb=1;\n\na = a2 = 1;\ng2=g;",
  "shape_2_per_frame": "if (instance==0, s1=3; s2=13,0);\nzmax = 8;\nk1 = instance/num_inst;\nbs=4096;\nreg60 = time*.08;\ns1 = s1%bs*3036 + s1/bs;\ns2 = s2%bs*3288 + s2/bs;\nz = k1-reg60; z = (z-int(z))*zmax;\nx = (s1%bs/bs-.5)/z+.5;\ny = (s2%bs/bs-.5)/z*reg32+0.5;\nrad = .025/z*reg32 ;\na = pow((zmax-z)/zmax,0.5);\nr = 0.7 + 0.29*sin(instance);\nr2=0;\na *= x<0.95-rad/2;\na2=1;\n",
