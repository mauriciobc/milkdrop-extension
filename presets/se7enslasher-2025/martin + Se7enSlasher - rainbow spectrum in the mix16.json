  "init_eqs": "n=0; loop (5000, gmegabuf(n)=0; n+=1);",
  "frame_eqs": "dec_f = pow (0.5, 50/fps);\ndec_m = pow (0.84,50/fps);\ndec_s = 1-0.6/fps;\n\nvol = (bass+mid+treb)/3;\nvol_ = dec_m * vol_ + (1-dec_m)*vol;\navg = avg*dec_s + vol*(1-dec_s);\nis_beat = above(vol, 1*avg+2*peak) * above (time, t0+.2);\nt0 = is_beat*time + (1-is_beat)*t0;\npeak = is_beat * vol + (1-is_beat)*peak*dec_m;\nindex = (index + is_beat) %8;\nindex2 = (index2 + is_beat*bnot(index)) %8;\n\ntrig = is_beat*(index==0);\nt1 = t1+trig;\nreg32 = aspecty;\n\nreg19 *= dec_s;\nreg20= reg20*dec_s + (1-dec_s)*reg19*2;\nreg20 = min(10,max(0.05,reg20));\nmonitor = reg20;\n\nreg00 = dec_f*0;\nreg01 = dec_m;\nreg02 = dec_s;\n\nreg05 = vol_>.1; //!stop\n\nmonitor = dec_m;",
