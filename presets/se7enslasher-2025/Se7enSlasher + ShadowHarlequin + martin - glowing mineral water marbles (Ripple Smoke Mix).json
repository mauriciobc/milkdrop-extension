  "shape_0_init": "bob = 1.54;\nro = 0;\nred = int(rand(20));",
  "shape_0_per_frame": "vol = 1 + 0.2*((bass_att+treb_att+mid_att)/3);\nbob = bob*above(bob,0.0091) - 0.0091 + 1*(1 - above(bob,0.0091));\nbob = 0.4 + 0.4*sin(time*0.8);\nbob = bob*vol;\n//rad = bob;\nborder_1 = 0.41;\nsides = 30;\nro = ro + 0.02;\nang = ro;\n//rad = 0.6;\n\nsp = red*0.025;\nspi = 0.5 - sp;\ntm = time*0.1;\nborder_r = 0.5 + sp*sin(tm*0.6) + spi*cos(tm*1.46);\nborder_g = 0.61 + sp*sin(tm*1.3846) + spi*cos(tm*0.809);\nborder_b = 0.48 + sp*sin(tm*1.0919) + spi*cos(tm*0.866);\n",
  "shape_1_per_frame": "x = 0.5 + 0.225*sin(time /instance*0.7);\ny = 0.54 + 0.36*cos(time /instance*0.62);\nx = x- 0.4*x*sin(time);\ny = y- 0.44*y*cos(time);\n\n\n\nrad = rad*mid_att;\nr = 0.5 + 0.5*sin(frame*0.5);\nb = 0.66 + 0.66*sin(frame*0.66 + 2.2615);\ng = 0.5 + 0.5*sin(frame*0.5 + 4.188);\n",
  "shape_2_per_frame": "x = 0.4331 + 0.4331*(sin(time*0.87)*0.35 + 0.7*sin(time*0.4331));\nx = 0.39 + 0.1822*sin(time + 1.693);\ny = 0.5 + 0.3*cos(time + 2.09);\n\nrad = rad*bass_att;\nr = 0.5 + 0.5*sin(frame*0.5);\nb = 0.5 + 0.5*sin(frame*0.5 + 2.094);\ng = 0.427 + 0.427*sin(frame*0.427 + 3.9367);\n",
