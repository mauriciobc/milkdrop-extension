  "name": "Incubo_'s DeepMash Series #11",
  "description": "",
  "init_eqs": "movx = int(rand(10));\nmovy = int(rand(10));\nsw3 = 0;\nsw4 = -.7;\nspeed = .1;\nzang_ = int(rand(2));",
  "frame_eqs": "dec_m = pow (0.85, 30/fps); dec_s = pow (0.95, 30/fps);\n\nbeat = bass+mid+treb;\navg = avg*dec_s + beat*(1-dec_s);\nis_beat = above(beat, .4+avg+peak) * above (time, t0+.2);\nt0a = if(bnot(is_beat),t0a,t0);\nt0 = is_beat*time + (1-is_beat)*t0;\npeak = is_beat * beat + (1-is_beat)*peak*dec_m;\nindex = (index + is_beat) %32;\nindex2 = (index2 + is_beat*bnot(index))%8;\n\nq20 = avg;\nq22 = peak;\nq24 = is_beat;\nq27 = index +1;\nq28 = index2;\nZDist =  .25 + .5*pow(sin(zang_/2),2) ; //zoom ;\nq29 = .08/ZDist ;\nq31 = ZDist;\ntrig = q24 * bnot(index%8);\nsw0 = if (bnot(trig),sw0,1-above(int(rand(100)),90));\n\n\ntrig = q24 * bnot(index%4);\nsw1 = if (bnot(trig), sw1, int(rand(5)-2)*3.1416/2);\nsw2 = if (bnot(trig), sw2, int(rand(8))-4);\n\ntrig = q24 * above (abs(beat-avg), 2) * bnot(index%4);\n//speed = .2 * sw2 * ZDist * pow(xang,2) + .1;\nfps_ = fps_ * dec_s + (1-dec_s) * min(fps/30,2);\nspeed = (.4 + (index2%2)*.3)*ZDist;\ndir = dir + min(max(sw1-dir,-.5),.5)/fps*16;\nmonitor = speed;\n\nmovx = movx + cos(dir)/fps*speed ;\nmovy = movy + sin(dir)/fps*speed ;\nq5 = movx; q6 = movy;;\n\ntrig = q24 * bnot((index+8)%20);\nsw4 = if (bnot(trig), sw4, sin(int(rand(100)))*.7);\nxang = xang + min(max(sw4-xang,-.2),.2)/fps*4;\n\ntrig = q24 * bnot(index%12);\nsw3 = if (bnot(trig), sw3, sw3+int(rand(4)-2)*3.1416/2);\npulse = q27 * bnot((2+index2)%4)*3.1416/2*0;\nzang_ = zang_ + max(min(sw3-zang_,.1),-.1)/fps*16;\n//pulse = q27*1.57*bnot(index2%3);\nzang = zang_ + cos((movx-movy)/3)*2;\nyang = (.8-abs(xang))*sin(movy+movx);\n\nox = -0; oy = .0; oz = ZDist;\nmx = ox*cos(zang) - oy*sin(zang);\nmy = ox*sin(zang) + oy*cos(zang);\nox = mx;oy = my;\nmx = ox*cos(yang) + oz*sin(yang);\nmz = - ox*sin(yang) + oz*cos(yang);\nox = mx;oz = mz;\nmy = oy*cos(xang) - oz*sin(xang);\nmz = oy*sin(xang) + oz*cos(xang);\noy = my;oz = mz;\nq11=ox; q12 = oy; q13 = oz; //Position\n\n//Vektor x nach rechts\nox = 1; oy = 0; oz = 0;\nmx = ox*cos(zang) - oy*sin(zang);\nmy = ox*sin(zang) + oy*cos(zang);\nox = mx;oy = my;\nmx = ox*cos(yang) + oz*sin(yang);\nmz = - ox*sin(yang) + oz*cos(yang);\nox = mx;oz = mz;\nmy = oy*cos(xang) - oz*sin(xang);\nmz = oy*sin(xang) + oz*cos(xang);\noy = my;oz = mz;\nq14=ox; q15 = oy; q16 = oz;\n\n\n//Vektor z nach hinten\nox = 0; oy = 0; oz = 1;;\n\nmx = ox*cos(zang) - oy*sin(zang);\nmy = ox*sin(zang) + oy*cos(zang);\nox = mx;oy = my;\nmx = ox*cos(yang) + oz*sin(yang);\nmz = - ox*sin(yang) + oz*cos(yang);\nox = mx;oz = mz;\nmy = oy*cos(xang) - oz*sin(xang);\nmz = oy*sin(xang) + oz*cos(xang);\noy = my;\noz = mz;\nq17=ox; q18 = oy; q19 = oz;",
