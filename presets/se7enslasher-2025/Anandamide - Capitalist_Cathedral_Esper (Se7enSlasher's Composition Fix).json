  "wave_0_init": "t2 = 0",
  "wave_0_per_frame": "\n\nt1 = time * 13;\n\nt2 = sin(time*3) * 0.5 + 0.5;\nt2 = t2 * 0.1 + 0.1; //size of circle;\n\nt2= q3 * 0.003 + 0.06;\n\nt3= 6.283;\n\nt4 = time/8;\n\nt5 = sin( time / 4 ) * 0.5 + 0.5; //bias value\nt5 = t5 * 17 + 2;",
  "wave_0_per_point": "n = sample*6.283;\npi = 3.1415;\npi2 = 6.283;\n\nphs = t1 + sample*9;\n\nbias = t5;\nbias_i = bias - 1;\n\ncc = phs / 3;\ncc_int = int(cc);\ncc_ramp = cc - cc_int;\ncc_ad_a = (cc_ramp * bias - 1) / bias_i;\ncc_ad_a = if( below(cc_ad_a,0) , 0 , cc_ad_a );\n\ncc_ad_b = cc_ramp * bias;\ncc_ad_b = if( above(cc_ad_b,1) , 1 , cc_ad_b );\n\ncc_a = cc_ad_a + cc_int;\ncc_b = (cc_ad_b + cc_int) ;\n\nxp = t2 * above(cc_ad_a , 0);\nyp = 1;\nzp = 0;\n\nang = cc_a * 6.283 * 16;\nsang = sin(ang) ; cang = cos(ang);\nxq = sang*xp + cang*zp;\nyq = yp;\nzq = cang*xp - sang*zp;\nxp=xq;yp=yq;zp=zq;\n\nang2 = cc_b + t4;\nsang = sin(ang2) ; cang = cos(ang2);\nxq = xp;\nyq = sang*yp + cang*zp;\nzq = cang*yp - sang*zp;\nxp=xq;yp=yq;zp=zq;\n\nang2 = cc_b * 3.13 + t4;\nsang = sin(ang2) ; cang = cos(ang2);\nxq = sang*xp + cang*yp;\nyq = cang*xp - sang*yp;\nzq = zp;\nxp=xq;yp=yq;zp=zq;\n\nang2 = cc_b * 1.43 + t4;\nsang = sin(ang2) ; cang = cos(ang2);\nxq = sang*xp + cang*zp;\nyq = yp;\nzq = cang*xp - sang*zp;\nxp=xq;yp=yq;zp=zq;\n\n//size xy\nxp = xp * 0.4;\nyp = yp * 0.4;\n\n//fade past depth for fake depth occlusion\nfade = min( (1.0 - zp*5.0), 1.0 );\nfade = max( fade, 0.0 );\n\nfade2 = abs( xp * 8.0 );\nfade2 = max( fade2 - 1.8, 0.0 );\nfade2 = min( fade2, 1.0 );\nfade = max( fade, fade2 );\na = a * fade;\n\nzp = zp+3.1;\nxs = xp/zp + 0.5;\nys = yp/zp * 1.333 + 0.5;\n\nx=xs+0.42;\ny=ys-0.18;\n\n\n",
  "wave_1_init": "t2 = 0",
  "wave_1_per_frame": "\n\nt1 = time * 13;\n\nt2 = sin(time*3) * 0.5 + 0.5;\nt2 = t2 * 0.1 + 0.1; //size of circle;\n\nt2= q3 * 0.003 + 0.06;\n\nt3= 6.283;\n\nt4 = time/8;\n\nt5 = sin( time / 4 ) * 0.5 + 0.5; //bias value\nt5 = t5 * 17 + 2;",
  "wave_1_per_point": "n = sample*6.283;\npi = 3.1415;\npi2 = 6.283;\n\nphs = t1 + sample*9;\n\nbias = t5;\nbias_i = bias - 1;\n\ncc = phs / 3;\ncc_int = int(cc);\ncc_ramp = cc - cc_int;\ncc_ad_a = (cc_ramp * bias - 1) / bias_i;\ncc_ad_a = if( below(cc_ad_a,0) , 0 , cc_ad_a );\n\ncc_ad_b = cc_ramp * bias;\ncc_ad_b = if( above(cc_ad_b,1) , 1 , cc_ad_b );\n\ncc_a = cc_ad_a + cc_int;\ncc_b = (cc_ad_b + cc_int) ;\n\nxp = t2 * above(cc_ad_a , 0);\nyp = 1;\nzp = 0;\n\nang = cc_a * 6.283 * 16;\nsang = sin(ang) ; cang = cos(ang);\nxq = sang*xp + cang*zp;\nyq = yp;\nzq = cang*xp - sang*zp;\nxp=xq;yp=yq;zp=zq;\n\nang2 = cc_b + t4;\nsang = sin(ang2) ; cang = cos(ang2);\nxq = xp;\nyq = sang*yp + cang*zp;\nzq = cang*yp - sang*zp;\nxp=xq;yp=yq;zp=zq;\n\nang2 = cc_b * 3.13 + t4;\nsang = sin(ang2) ; cang = cos(ang2);\nxq = sang*xp + cang*yp;\nyq = cang*xp - sang*yp;\nzq = zp;\nxp=xq;yp=yq;zp=zq;\n\nang2 = cc_b * 1.43 + t4;\nsang = sin(ang2) ; cang = cos(ang2);\nxq = sang*xp + cang*zp;\nyq = yp;\nzq = cang*xp - sang*zp;\nxp=xq;yp=yq;zp=zq;\n\n//size xy\nxp = xp * 0.45 -(bass_att*0.05);\nyp = yp * 0.45 -(treb_att*0.05);\n\n//fade past depth for fake depth occlusion\nfade = min( (1.0 - zp*5.0), 1.0 );\nfade = max( fade, 0.0 );\n\nfade2 = abs( xp * 8.0 );\nfade2 = max( fade2 - 1.8, 0.0 );\nfade2 = min( fade2, 1.0 );\nfade = max( fade, fade2 );\na = a * fade;\n\nzp = zp+3.1;\nxs = xp/zp + 0.5;\nys = yp/zp * 1.333 + 0.5;\n\nx=xs+0.42;\ny=ys-0.18;\n\n\n",
  "wave_3_init": "t1 = 0;",
  "wave_3_per_frame": "t1 = 3.1415 / 8 - 0.020;\n\nt2 = time - int(time);\nt2 = t2*5;\na=(bass_att*0.05)",
  "wave_3_per_point": "t1 = t1 + 0.25;\n\nn = sample*6.283;\n\nxp = sin(t1*6.283);\nyp = cos(t1*6.283);\nzp = 3 + sample*400 - t2;\n\nx = xp/zp + 0.4;\ny = yp/zp * 1.333 + 0.5;",
  "shape_0_init": "x = 0.410;",
  "shape_0_per_frame": "//x = 0.416;\n//ang = time;\nr=bass_att*.2;\nb=.2+treb_att*.5;\n\na2 = a2 * (1.0-q1);",
  "shape_1_per_frame": "ang=sin(time*(treb_att*.2));\nr2=bass;\nx=.880+ min((sin(time)*(0.7-(sin(time*0.3)*0.5+0.5)*0.2)),0);\n//y=.320- min((cos(time*.2)*0.5+0.2),0.320) / min((sin(time)*0.5),.320);\ny=.320- max((cos(time)*0.1-0.5+((sin(time*0.1)*0.5+0.5)*0.2)),.01);\nrad=.180*((cos(time)*0.1)/0.1)",
  "shape_2_per_frame": "ang=sin(time*(treb_att*.2));\nr2=bass;\nx=.880+ min((sin(time)*0.4),0);\ny=.320- min((cos(time*.4)*0.5+0.2),0.320) * min((cos(time)*0.6),1);\n//y=.320+ max((sin(time)),.01);\nrad=.180*((cos(time)*0.1)/0.1)",
  "shape_3_per_frame": "ang=sin(time*(treb_att*.2));\nr2=bass;\nx=.880+ min((sin(time)*(0.6-(sin(time*0.1)*0.5+0.5)*0.2)),0) + max((sin(time)*0.1),.01);\n//y=.320- min((cos(time*.2)*0.5+0.2),0.320) / min((sin(time)*0.5),.320);\ny=.320+ max((cos(time)*0.1-0.5+((sin(time*0.1)*0.5+0.5)*0.2)),.01);\nrad=.180*((cos(time)*0.1)/0.1)"
