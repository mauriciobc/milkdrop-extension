  "init_eqs": "mv_x=64;mv_y=48;\nnut=0;\nstp=0;stq=0;\nrtp=0;rtq=0;\nwvr=0;\ndecay=0;\ndcsp=0\n",
  "frame_eqs": "decay=0.96;\nzoom=1.000;\n\nvol=(bass+mid+treb)*0.25;\nvol=vol*vol;\nq7=vol;\n\nvol=(bass_att+mid_att+treb_att)*0.25;\nvol=vol*vol;\nq8=vol;\n\nmtime = mtime + vol*0.02;\nq6 = mtime;\n\n\n//krash's beat detection code\nvolume = 0.3*(bass+mid+att);\nbeatrate = equal(beatrate,0) + (1-equal(beatrate,0))*(below(volume,0.01) + (1-below(volume,0.01))*beatrate);\nlastbeat = lastbeat + equal(lastbeat,0)*time;\nmeanbass_att = 0.1*(meanbass_att*9 + bass_att);\npeakbass_att = max(bass_att,peakbass_att);\nbeatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);\npeakbass_att = beat*bass_att + (1-beat)*peakbass_att*(above(time - lastbeat, 2*beatrate)*0.95 + (1-above(time - lastbeat, 2*beatrate))*0.995);\nlastbeat = beat*time + (1-beat)*lastbeat;\npeakbass_att = max(peakbass_att,1.1*meanbass_att);\nbeat = above(volume,0.8)*below(peakbass_att - bass_att, 0.05*peakbass_att)*above(time - lastbeat, 0.1 + 0.5*(beatrate - 0.1));\nbeatcounter = beatcounter + beat;\nmode = if(beat*equal(beatcounter%2,0),-mode,mode);\nflip = 2*mode-1;\n\nbeatdrop = if( equal(pass,0) , beat , beatdrop );\npass = (pass+beat)%4;\nrot=(rot+beatdrop*flip*q6*.05);\nq3=rot;\n\nwarp =0.3 * beatdrop;\n//end beat detection\n\ntic = min(time-tin,.1);\ntin = time;\n\nra = 1/tic*.25;\ntreb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);\nmid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);\nbass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);\nvav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);\n\ntt = tt + tic*treb;\nmt = mt + tic*mid;\nbt = bt + tic*bass;\nvt = vt + tic*vav;\n\nq1 = sin(vt*.2)*.25 - treb_avg*.5;\nq2 = cos(vt*.2)*.25 - mid_avg*.5;\nq3 = sin(vt*.1)*.25 - bass_avg*.5;\n\nst = .05;\nspeed = 1;\nhro = speed*tt*st + q1;\nhco = speed*mt*st + q2;\nhio = speed*bt*st + q3;\n\n//rot = hro;\n//q3=hco;\n//q4=hio\nq5=speed;\n\n\n\nbb = bb*0.99 + bass*0.02;\nmm = mm*0.99 + mid*0.02;\ntt = tt*0.99 + treb*0.02;\n\nq6 = (bb-tt)*5;\nq7 = (mm-tt)*5;",
  "pixel_eqs": "kdx=dx;//////////////////////////////////////////\nkdy=dy;\nksx=sx;\nksy=sy;\nkrt=rot;\nkzm=zoom;\nkcx=cx;\nkcy=cy;\nkwp=warp;\n\ndx=0;\ndy=0;\nsx=1;\nsy=1;\nrot=0;\nzoom=1;\ncx=.5;\ncy=.5;\nwarp=0;\n\njx1 = 0.5+sin(time*0.618)*0.2;\njy1 = 0.5+cos(time*1.618)*0.2;\njx2 = 0.5+sin(time*1.618)*0.2;\njy2 = 0.5+cos(time*0.618)*0.2;\ndist = sqrt(pow((x-jx1),2)+pow((y-jy1),2));\nnear = below(dist,0.3);\ndist = sqrt(pow((x-jx2),2)+pow((y-jy2),2));\nnear = near + below(dist,0.3);\n\njuice = 0.5*bass_att*above(bass_att,1);\nkick = near * above(bass,1.2) * above(rot,0) * below(sin(time),0);\nkick = kick + below(sin(time*1.1),0) * above(bass,1.2) * above(rot,0) * near;\nrot = rot*(1-kick) + 0.5*kick;\ncx = cx + 0.25*sin(time)*(1-2*near) + 0.15*sin(time*juice)*(1-2*near);\ncy = cy + 0.25*cos(time)*(1-2*near) + 0.15*cos(time*juice)*(1-2*near);\nsx = sx + 0.01*(1-2*near) * (sin(time*1.1)*0.7 + 0.3*sin(time*0.4));\nsy = sy + 0.01*(1-2*near) * (cos(time*1.1)*0.3 + 0.7*cos(time*0.4));\nzoom = zoom - 0.05*(1-2*near);\n\n///////////////////////////////////////\ncr1=(int(sin(y*10)*5+5))*.2;\ncr2=cr1;\ncrx=cr2-cr1;\nci=rad;\ncb=.25  ;\ncrs=2;\ncr=pow(sin(ci*6.3-(cb*6.3))/2+.5,crs)*crx+cr1;\ncqr=if( above (ci,.25+cb),cr,crx+cr1);crr=if( below(ci,1.5),cqr,crx+cr1);\njx1 = 0.5+sin(time*0.618)*0.2;\njy1 = 0.5+cos(time*1.618)*0.2;\njx2 = 0.5+sin(time*1.618)*0.2;\njy2 = 0.5+cos(time*0.618)*0.2;\ndx=(x-jx1)*(crr);///////////////////////////////////////\ndy=(y-jy1)*(crr);\nsx=sx-(x-jx2)*((1-crr)/10);\nsy=sy-(y-jy2)*((1-crr)/10);\n///////////////////////////////////////\nzoom = zoom + (rad*rad-rad)*(1-rad*.5);\n///////////////////////////////////////\nkdx=dx;\nkdy=dy;\nksx=sx;\nksy=sy;\nkrt=rot;\nkzm=zoom;\nkcx=cx;\nkcy=cy;\nkwp=warp;\n\ndx=(sin(y*10)*0.025);\ndy=(cos(x*10)*0.025);\nsx=sx-(x-jx2)*(1-rad)*0.05;\nsy=sy-(y-jy2)*(1-rad)*0.05;\n\ncx=cos(y*10+time*10)*0.2+0.5;\ncy=sin(x*10+time*10)*0.2+0.5;\nrot=sin(time/3)*0.01;\nzoom=zoom-(y/19*sin(time/4)*rad*10);\n\nkdx=dx;///////////////////////////////////////\nkdy=dy;\nksx=sx;\nksy=sy;\nkrt=rot;\nkzm=zoom;\nkcx=cx;\nkcy=cy;\nkwp=warp;\n\ndx=(x-0.5)*0.1;\ndy=(y-0.5)*0.1;\nsx=sx-(x-jx2)*(1-rad)*0.05;\nsy=sy-(y-jy2)*(1-rad)*0.05;\n\n///////////////////////////////////////\nzoom = zoom + sin(ang*3+time/3)*0.1;\n///////////////////////////////////////\ncr1=(int(sin(y*10)*5+5))*.2;\ncr2=cr1;\ncrx=cr2-cr1;\nci=rad;\ncb=.25  ;\ncrs=2;\ncr=pow(sin(ci*6.3-(cb*6.3))/2+.5,crs)*crx+cr1;\ncqr=if( above (ci,.25+cb),cr,crx+cr1);crr=if( below(ci,1.5),cqr,crx+cr1);\njx1 = 0.5+sin(time*0.618)*0.2;\njy1 = 0.5+cos(time*1.618)*0.2;\njx2 = 0.5+sin(time*1.618)*0.2;\njy2 = 0.5+cos(time*0.618)*0.2;\ndx=(x-jx1)*(crr);///////////////////////////////////////\ndy=(y-jy1)*(crr);\nsx=sx-(x-jx2)*((1-crr)/10);\nsy=sy-(y-jy2)*((1-crr)/10);\n///////////////////////////////////////\nzoom = zoom + (rad*rad-rad)*(1-rad*.5);\n///////////////////////////////////////\nkdx=dx;//////////////////////////////////////////\nkdy=dy;\nksx=sx;\nksy=sy;\nkrt=rot;\nkzm=zoom;\nkcx=cx;\nkcy=cy;\nkwp=warp;\n\ndx=(sin(y*10)*0.025);\ndy=(cos(x*10)*0.025);\nsx=sx-(x-jx2)*(1-rad)*0.05;\nsy=sy-(y-jy2)*(1-rad)*0.05;\n\n///////////////////////////////////////\nzoom = zoom + sin(ang*3+time/3)*0.1;\n///////////////////////////////////////",
