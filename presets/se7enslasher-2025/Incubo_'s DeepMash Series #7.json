  "wave_0_init": "t2 = 0;\nt3 = 0;\nt4 = 0;\nab = 1;",
  "wave_0_per_frame": "// parameters\nw = time*0.5; // rotation (0..2Pi)\nt1 = 0.5; // center for rotation (x)\nt2 = 0.5; // center for rotation (y)\nt3 = 1; // scale\nt4 = 0; // translation (x)\nt5 = 0; // translation (y)\nt6 = sin(w);\nt7 = cos(w);",
  "wave_0_per_point": "xx = if(equal(sample,0),q3,xx);\nyy = if(equal(sample,0),q4,yy);\n\n\ndx = xx*(1-xx)-q5*xx*yy/(xx+q6);\ndy = q7*yy*(1-yy/xx);\n\nx1 = xx;\ny1 = yy;\n\nxx = xx+dx*0.2;\nyy = yy+dy*0.2;\n\nx1 = 0.5+(x1-0.5)/q1 + dy*value1*0.01;\ny1 = 0.5+(y1-0.5)/q2 - dx*value1*0.01;\n\n\n// synchronized affine transformation\nx = q26 + ((x1-q26)*q32 + (y1-q27)*q31)*q28 + q29;\ny = q27 + (-(x1-q26)*q31 + (y1-q27)*q32)*q28 + q30;",
  "wave_1_per_point": "xx1 = if(equal(sample,0),q11,xx1);\nyy1 = if(equal(sample,0),q12,yy1);\nzz1 = if(equal(sample,0),q13,zz1);\n\ndx1 = q14*(yy1-xx1);\ndy1 = xx1*(q15-zz1)-yy1;\ndz1 = xx1*yy1-q16*zz1;\nxx1 = xx1 + q17*dx1;\nyy1 = yy1 + q17*dy1;\nzz1 = zz1 + q17*dz1;\n\nmy_x = xx1*0.02;\nmy_y = yy1*0.02;\nmy_z = zz1*0.02;\n\nx = 0.5 + my_x;\ny = 0.5 + my_y;",
  "shape_2_per_frame": "x = sin(time) * .4 + .5;\n\n\npow( (bass*.15),2);",
  "shape_3_per_frame": "x = 1-q1;\ny = q2;\nx = 0.5 + (x - 0.5)*0.25;\ny = 0.5 + (y - 0.5)*0.25;"
