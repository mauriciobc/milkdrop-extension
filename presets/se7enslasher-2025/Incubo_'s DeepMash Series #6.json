  "wave_0_per_frame": "t1 = 0;\nt2=3*sin(time*0.025);\nmo+=treb/fps/18;\nt3= pow(sin(mo),4)*0.05;\nreg99=t3;",
  "wave_0_per_point": "ni = 512;\nd=int(time*8);\ni = abs ((t1+d)%ni);;\nrx1 = gmegabuf (i*8+5);\nrx2 = gmegabuf ((ni-i-1)*8+5);//mirrored\nry1 = gmegabuf (i*8+6);\nry2 = gmegabuf ((ni-i-1)*8+6);//mirrored\n\nx= (rx1 - rx2) + (1-q25/2) - sample*(1-q25/2) ;\n\ny0 = (ry1+ry2*q26);\ny0=(q24*abs(y0)+(1-q24)*y0);\ny0 = y0*(1-q23)+q23*(rx1-rx2)*2;\n\ny = y0+0.502 + 0.01*(1-q24) + t3*cos(sample*18+time);\n\nr = 0.5 + 0.3*sin(rx1*19+sample*8+2+t2);\ng = 0.5 + 0.3*sin(rx2*19+sample*8+1+t2);\nb = 0.5 + 0.3*sin(ry1*19+sample*8+t2);\nlum = sqrt(r*r+b*b+g*g);\n\nr=min(1,r/lum);\ng=min(1,g/lum);\nb=min(1,b/lum);\n\na = 0.55-q25*0.1 ;\na*= min(1.3,0.5+16*abs(y0));;\n\nt1 += 1;\n",
