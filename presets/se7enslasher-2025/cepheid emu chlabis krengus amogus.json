  "wave_0_init": "t2 = 0;\nt3 = 0;\nt4 = 0;\ncl = 0;",
  "wave_0_per_frame": "vol = bass*8 + mid*5 + treb*3;\nm = m*0.97 + vol*0.08;\nmonitor = vol;\nbeat = above(vol,res)*above(vol,m)*above(vol,16);\ndiff = (1-beat)*diff + beat*(vol-res);\nres = beat*(vol + m*0.04) + (1-beat)*(res -  (0.1+diff*0.02)*60/fps);\nres = max(0,res);\nb = beat;\ng = 1-beat;",
  "wave_0_per_point": "tt3 = tt3*0.6 + (value1)*1;\ntt2 = tt2*0.7 + tt3*0.2;\ntt1 = tt1*0.8 + tt2*0.1;\nd = d*0.9 + tt1*0.2;\n\ny = 0.5 + d*sample*(1-sample)*4;\nx =  -0.05 + sample*1.1;",
  "wave_1_init": "t2 = 0;\nt3 = 0;\nt4 = 0;\ncl = 0;",
  "wave_1_per_point": "w = sample*asin(1)*4;\nd = 0.04;\nx = 0.5 + sin(w)*d;\ny = 0.5 + cos(w)*d;",
  "wave_2_per_frame": "t1 = q1;\nt2 = q2;\nt3 = q3;\nt4 = q4;\nt5 = q5;\nt6 = q6;\nt7 = q7;\nt8 = q8;",
  "wave_2_per_point": "sample = 1-sample;\nxxx = xx;\nyyy = yy;\nxx = pow(sample,5)*t1 + 5*pow(sample,4)*(1-sample)*t1 + 10*pow(sample,3)*sqr(1-sample)*t2\n+ 10*sqr(sample)*pow(1-sample,3)*t3 + 5*pow(1-sample,4)*sample*t4 + pow(1-sample,5)*t4;\n\nyy = pow(sample,5)*t5 + 5*pow(sample,4)*(1-sample)*t5 + 10*pow(sample,3)*sqr(1-sample)*t6\n+ 10*sqr(sample)*pow(1-sample,3)*t7 + 5*pow(1-sample,4)*sample*t8 + pow(1-sample,5)*t8;\nd = 1/sqrt(sqr(xx-xxx)+sqr(yy-yyy));\nx = xx + sample*(1-sample)*(value1-value2)*(yy-yyy)*d;\ny = yy - sample*(1-sample)*(value1-value2)*(xx-xxx)*d;",
  "wave_3_init": "t2 = 0;\nt3 = 0;\nt4 = 0;\ncl = 0;",
  "wave_3_per_frame": "t8 = 1;",
