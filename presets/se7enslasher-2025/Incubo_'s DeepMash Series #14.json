  "wave_0_init": "t1 = rand(100)/300+.5;\nt2 = rand(100)/100+1;",
  "wave_0_per_point": "r = 1; b = 10; g = 0;\n\ninstance = sample*t2*21;\nang1 = sin(t2*26*instance)*16;\nrad1 = sample;\n\nx = t1 + .15*rad1*cos(ang1);\ny = .5 + .03*rad1*sin(ang1);;\na = .3/rad1;",
  "wave_1_per_frame": "t1 = 2*sin(time/15);\nt2 = 2*sin(time/11);\nmonitor = time;",
  "wave_1_per_point": "k1 = sample*6.28;\n\noz = k1 + time*.04;\noz = 1 + int(oz)-oz;\n\nox = sin(k1*72);\noy = cos(k1*31);\n\nfov = .20;\n//oz = oz*oz;\n//oz = sqrt(oz);\n\nk2 = .0;\nx = fov*ox/(oz+k2)+.5;\ny = fov*oy/(oz+k2)+.5;\nrad = .03/oz;\na = above(oz,0)*1 * max(0,(1-oz));",
  "wave_2_per_frame": "\nt1 = sin(time*3);\nt2 = cos(time*3);\n\nt3 = sin(time/3);\nt4 = cos(time/3);\n\nt5 = cos(time/4);\n\n//give him a break\n//bird = 1;\n\nground = below(t5,-.9);\ntrig = below(rand(100),1);\ntrig = trig * bnot(ground) * bnot(bird);\nbird = bird * bnot(ground);\n\nbird = bnot(bird)*trig;\n\nt6 = bird;",
  "wave_2_per_point": "\nr = 0; g = 1; b = 0;\nk1 = below(sample,.5);\n\ndx = .02*k1*sin(sample*50);\n\n//clb = above(sin(time/3),0);\n\nf1 = sqr(dx);\n\ndy =  20*f1*t1 + t2/150;\ndy = dy+ (1-k1) * .004*sin(sample*50);\n\nx = dx + .5 + .1*t3;\n\ndy = dy + +.2*dx*t4;\n\ny0 = y0 + time/7;\ny0 = y0 - int(y0) ;\ny0 = t5;\ny = dy+ .7 + y0/8;\n\na = .4;\n",
  "shape_0_per_frame": "k1 = instance/num_inst*6.28;\n\noz = k1 + time*.04;\noz = 1 + int(oz)-oz;\n\nox = sin(k1*72);\noy = cos(k1*31);\n\nfov = .020;\noz = oz*oz;\n//oz = sqrt(oz);\n\nk2 = .0;\nx = fov*ox/(oz+k2)+.5;\ny = 2*fov*oy/(oz+k2)+.5;\nrad = .04/oz;\na = above(oz,0)*.5 * max(0,(1-pow(oz,2))*sqrt(oz));",
  "shape_1_per_frame": "k1 = instance/num_inst*6.28;\n\noz = k1 + time/8;\n\nox = sin(k1*172);\noy = cos(k1*131);\n\nfov = .1;\noz = .2;\n\nx = fov*ox/oz+.5;\ny = fov*oy/oz+.5;\nrad = .005;\na = above(oz,0);"
